#!/bin/bash

date_str=$1
output_path=$2

if [ -z "$date_str" ]; then
  echo "No archive suffix"
else
  script_dir="$(cd "$(dirname "$0")" && pwd)"
  if [ -n "$AGSDEST" ]; then
    agsdest="${AGSDEST%/}"
    agsdest="${agsdest#\"}"
    agsdest="${agsdest%\"}"
    agsdest="${agsdest#\'}"
    agsdest="${agsdest%\'}"
    output_dir="$agsdest/CD32-Output"
  else
    output_dir="$(cd "$script_dir/../.." && pwd)/AmigaVision-Output/CD32-Output"
  fi
  arc_name="!AmigaVision-CD32-MiSTer-$date_str.zip"
  if [ -z "$output_path" ]; then
    output_path="$script_dir/$arc_name"
  fi
  stage_dir="$(mktemp -d)"
  trap 'rm -rf "$stage_dir"' EXIT
  rm -f "$output_path"
  cp -R "$output_dir"/. "$stage_dir/"
  cp "$script_dir/ReadMe.txt" "$stage_dir/ReadMe.txt"
  (
    cd "$stage_dir" || exit 1
    zip -rq "$output_path" . -x '*/.DS_Store' '.DS_Store' '*/._*' '._*' '__MACOSX/*'
  )
fi
